@use './../../../styles/tokens/typography' as *;
@use './../../../styles/tokens/colors' as *;




.inputWrapper {
    position: relative;
    height: 80px;

    &--textarea {
        height: auto;
        min-height: 80px;
    }
}


.input {
    border-bottom: $neutral_600 3px solid;

    @extend .body-16-magra-bold;

    color: $neutral_200;
    line-height: $leading-loose;

    transition: all ease-in-out .2s;

    &:placeholder-shown {
        color: $neutral_600;
    }

    @media (min-width: 1280px) {
        &:hover {
            border-bottom: $neutral_400 3px solid;
            color: $neutral_400;

            .inputIcon {
                opacity: 1;
            }
        }
    }
    

    &:focus {
        border-bottom: $neutral_200 3px solid;
        color: $neutral_200;


        .inputIcon {
            opacity: 1;
        }
    }

        @media (min-width: 768px) {
            font-size: 20px;
        }
}

.inputError {
    border-bottom: $error_600 3px solid;
}


.inputWithIcon {
    padding: 0 40px;

    @media (min-width: 1280px) {
        padding: 0 50px;
    }
}



.inputIcon {
    position: absolute;

    top: 5px;
}


.inputIconLeft {
    left: 10px;
}


.inputIconRight {
    right: 10px;
}

.inputIcon {
    path {
        transition: stroke 0.3s ease, fill 0.3s ease;
    }
}

.inputErrorText {
    @extend .body-14-mont-regular;
    margin-top: 5px;

    @media (min-width: 1280px) {
        font-size: 16px;
        margin-top: 15px;
    }
    
    color: $error_600;
}


.input-textarea {
    line-height: 1;
}

.inputWrapper-textarea {
    height: auto;
    min-height: 100px;
}


