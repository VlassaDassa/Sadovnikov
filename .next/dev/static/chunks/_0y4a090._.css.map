@use './../../../styles/tokens/colors' as *;
@use './../../../styles/tokens/typography' as *;
@use './../../../styles/tokens/effects' as *;




.statusMessage {
    @extend .heading-20-magra-bold;
    @extend .radius-12;
    @extend .whiteText;

    display: inline-block;
    opacity: 0;
    position: fixed;
    width: calc(100% - 130px);
    text-align: center;
    z-index: 30;
    top: -100px;
    left: 50%;
    transform: translateX(-50%);

    padding: 10px 50px;
    animation: fadeUp 0.3s ease-in forwards;
    transition: all 0.3s cubic-bezier(0.68, -0.55, 0.265, 1.55); 
    
    @media (min-width: 768px) {
        font-size: 24px;
        padding: 20px 100px;
        border-radius: 24px;
    }

    @media (min-width: 600px) {
        width: auto;
    }

    @media (min-width: 1280px) {
        font-size: 32px;
    }
}


.statusMessage-info {
    background-color: $info_600;
}

.statusMessage-warning {
    background-color: $warning_600;
}

.statusMessage-error {
    background-color: $error_600;
}


.statusMessage-show {
    opacity: 1;
    top: 100px;

    animation: gentleBounce 0.5s cubic-bezier(0.34, 1.2, 0.64, 1) forwards;
}

@keyframes gentleBounce {
    0% {
        top: -100px;
        opacity: 0;
    }
    60% {
        top: 120px;        
        opacity: 1;
    }
    100% {
        top: 100px;        
        opacity: 1;
    }
}

@keyframes fadeUp {
    0% {
        top: 100px;
        opacity: 1;
    }
    100% {
        top: -100px;
        opacity: 0;
    }
}