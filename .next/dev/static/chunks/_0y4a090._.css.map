@use './../../../styles/tokens/colors' as *;
@use './../../../styles/tokens/typography' as *;
@use './../../../styles/tokens/effects' as *;




.header {
    padding: 50px 0;

    display: flex;
    justify-content: space-between;
}


.btnBurger {
    width: 44px;
    height: 44px;

    background-color: $brand_900;

    display: flex;
    align-items: center;
    justify-content: center;
    flex-direction: column;
    row-gap: 5px;

    transition: all ease-in-out .2s;


    span {
        height: 3px;
        width: 25px;

        background-color: $white;
    }

    @media (min-width: 1280px) {
        display: none;
    }

    &:hover {
        background-color: $brand_600;
    }

    &:active {
        transform: translateY(3px);
    }
}


.logo {
    display: flex;
    align-items: center;
    justify-content: center;    

    background-image: url('/images/button/bg_medium_btn.png');
    background-size: cover;

    width: 152px;
    height: 40px;
    transition: all ease-in-out .2s;
    filter: brightness(1);


    @media (min-width: 768px) {
        width: 190px;
        height: 50px;
    }

    @media (min-width: 768px) {
        width: 265px;
        height: 70px;
    }

    &:hover {
        @media (min-width: 768px) {
            filter: brightness(3);
        }
    }

    &:active {
        transform: translateY(3px);

        .decorBgBtnBig {
            transition: all .2s;
            opacity: 0.9;
        }
    }
}


.logoText {
    padding-right: 20px;

    @extend .body-16-magra-bold;
    @extend .whiteText;

    @media (min-width: 768px) {
        font-size: 20px;
    }

    @media (min-width: 1280px) {
        font-size: 24px;
    }
}


.headerNav {
    display: none;

    @media (min-width: 1280px) {
        display: flex;
    }

}


.headerNavList {
    display: flex;
    align-items: center;
    column-gap: 30px;
}


.headerNavItemLink {
    @extend .heading-20-mont-regular;
    color: $neutral_500;
    text-transform: uppercase;
    position: relative;

    transition: all ease-in-out .2s;

    z-index: 1;
    overflow: hidden;
     &::before {
        content: '';
        position: absolute;
        bottom: 0px;           
        left: 50%;
        transform: translateX(-50%);
        width: 3px;
        height: 3px;
        border-radius: 50%;
        background-color: $neutral_700;
        z-index: -1;             
        opacity: 0;
        transition: all 0.3s ease-out;
    }

    &:hover {
        color: $neutral_700;
        &::before {
            bottom: 30px;      
            opacity: 1;
        }
    }
}


.decorBtn-changeLang {
    z-index: 1;
}


.selectLang {
    position: absolute;
    width: 200px;
    padding: 10px;


    @extend .glass;
    @extend .radius-6;
    @extend .shadow-xl;

    flex-direction: column;
    row-gap: 5px;

    z-index: 3;

    opacity: 0;
    transform: translateY(-20px);
    visibility: hidden;
    pointer-events: none;

    transition: opacity 0.25s ease, transform 0.25s ease, visibility 0.25s;
}

.selectLangItem {
    @extend .body-20-mont-regular;
    @extend .whiteText;
    @extend .radius-6;

    display: flex;
    justify-content: space-between;

    height: 24px;
    background-color: unset;
    transition: all ease .1s;
    position: relative;

    align-items: center;
    padding: 8px 10px;
    cursor: pointer;

    &:hover {
        background-color: $neutral_700;
    }

    transition: all ease-in-out .1s;
    
    &:active {
        transform: translateY(3px);
        opacity: 0.9;
    }
}

.spanLang {
    color: $neutral_400;
}

.selectLang-show {
    opacity: 1;
    transform: translateY(0);
    visibility: visible;
    pointer-events: auto;
}