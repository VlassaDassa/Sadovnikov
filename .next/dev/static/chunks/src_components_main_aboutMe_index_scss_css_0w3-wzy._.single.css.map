@use './../../../styles/tokens/typography' as *;


.aboutMe {
    margin-top: 80px;
}


.aboutMeData,
.workExperienceWrapper, 
.workExperienceItem,
.shortBio {
    display: flex;
    flex-direction: column;
}

.aboutMeData {
    margin-top: 30px;
    margin-bottom: 40px;

    row-gap: 5px;
}


.workExperience {
    margin-bottom: 50px;
}


